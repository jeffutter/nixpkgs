#!/usr/bin/env bash
set -euo pipefail

PKG="${HOME}/.config/home-manager/pkgs/datadog-pup/default.nix"
REPO="DataDog/pup"

# Nix system → release-asset platform suffix. The suffix is what anchors each
# hash substitution, since the Nix file keeps `${version}` literal in the URL.
# Add new entries here when supporting more platforms.
systems=("aarch64-darwin" "x86_64-darwin" "aarch64-linux" "x86_64-linux")
suffixes=("Darwin_arm64.tar.gz" "Darwin_x86_64.tar.gz" "Linux_arm64.tar.gz" "Linux_x86_64.tar.gz")

echo "Fetching latest pup release..."
TAG=$(gh release view --repo "$REPO" --json tagName --jq '.tagName')
LATEST="${TAG#v}"

if [[ -z "$LATEST" || "$LATEST" == "null" ]]; then
  echo "error: failed to fetch latest release from GitHub" >&2
  exit 1
fi

CURRENT=$(grep 'version = ' "$PKG" | head -1 | sed 's/.*"\(.*\)".*/\1/')

echo "Current: $CURRENT  Latest: $LATEST"

if [[ "$LATEST" == "$CURRENT" ]]; then
  echo "Already at latest version, nothing to do."
  exit 0
fi

WORK="$(mktemp -d "${TMPDIR:-/tmp}/pup.XXXXXX")"
trap 'rm -rf "$WORK"' EXIT
BASE="https://github.com/${REPO}/releases/download/v${LATEST}"

# Update the version first so the URLs resolve to the new release.
perl -pi -e "s|version = \"[^\"]+\"|version = \"${LATEST}\"|" "$PKG"

# Refresh each platform hash. Hashes are intentionally never printed: this
# repo runs under DLP tooling that flags SRI/sha strings in command output.
for i in "${!systems[@]}"; do
  sys="${systems[$i]}"
  suffix="${suffixes[$i]}"
  fn="pup_${LATEST}_${suffix}"
  echo "Fetching ${sys} (${suffix})..."
  curl -sfL "${BASE}/${fn}" -o "${WORK}/${fn}"
  SRI="$(nix hash file --sri --type sha256 "${WORK}/${fn}")"
  SUFFIX="$suffix" HASH="$SRI" perl -0777 -pi -e '
    my $suffix = quotemeta($ENV{SUFFIX});
    s/(${suffix}";\s*\n\s*hash = ")[^"]*(")/$1$ENV{HASH}$2/;
  ' "$PKG"
done

echo "Updated datadog-pup: $CURRENT -> $LATEST"
